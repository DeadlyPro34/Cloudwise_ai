# ============================================================
# CloudWise AI - Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Database (Railway PostgreSQL connection string) ---
DATABASE_URL=sqlite:///./cloudwise.db

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Encryption (Fernet key for encrypting stored AWS credentials) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- CORS ---
# Local development:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Production (replace with your actual Render frontend URL):
# CORS_ORIGINS=https://your-app-name.onrender.com

# --- AWS ---
AWS_REGION=us-east-1
# For hackathon dev speed only (see Security Policy - prefer IAM roles in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- AI / Groq (Llama) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Rate Limits ---
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_COPILOT=30/minute

# --- Wolfram Alpha ---
# Get free Wolfram App ID at: https://products.wolframalpha.com/api/
# Free tier: 2000 queries/month. Required for Simulator verification.
WOLFRAM_APP_ID=
